<form id="contact-form" class="contact-form" action="https://formspree.io/f/mrevkzwp" method="POST">
  <div class="form-row">
    <input type="text" name="name" placeholder="Your Name" required data-fs-field />
    <input type="email" name="email" placeholder="Your Email" required data-fs-field />
  </div>
  <input type="text" name="company" placeholder="Company (optional)" data-fs-field />
  <textarea
    name="message"
    placeholder="Tell me about your project, tech stack, and QA needs..."
    required
    data-fs-field></textarea>
  <button type="submit" class="btn-primary form-submit" data-fs-submit-btn>Send Message</button>
  <div data-fs-success class="form-status form-status--success">Message sent! We'll reply within 24h.</div>
  <div data-fs-error class="form-status form-status--error"></div>
</form>

<script>
  window.formspree = window.formspree || function () { (formspree.q = formspree.q || []).push(arguments); };
  formspree('initForm', { formElement: '#contact-form', formId: 'mrevkzwp' });
</script>
<script src="https://unpkg.com/@formspree/ajax@1" defer></script>

<style>
