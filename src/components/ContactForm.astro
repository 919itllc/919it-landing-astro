<form id="contact-form" class="contact-form" action="https://formspree.io/f/mrevkzwp" method="POST">
  <div class="form-row">
    <input type="text" name="name" placeholder="Your Name" required />
    <input type="email" name="email" placeholder="Your Email" required />
  </div>
  <input type="text" name="company" placeholder="Company (optional)" />
  <textarea
    name="message"
    placeholder="Tell me about your project, tech stack, and QA needs..."
    required></textarea>
  <button type="submit" class="btn-primary form-submit">Send Message</button>
</form>

<style>
  .contact-form input, .contact-form textarea { width: 100%; padding: 15px 18px;
  margin-bottom: 12px; border: 1.5px solid var(--border-strong); border-radius:
  var(--radius-sm); font-family: 'Inter', sans-serif; font-size: 0.9rem;
  background: var(--bg-surface); color: var(--text-main); transition:
  border-color 0.25s, box-shadow 0.25s, background 0.25s; } .contact-form
  input::placeholder, .contact-form textarea::placeholder { color:
  var(--text-dim); font-weight: 400; } .contact-form input:focus, .contact-form
  textarea:focus { outline: none; border-color: var(--accent); box-shadow: 0 0 0
  3px var(--accent-dim); background: var(--bg-elevated); } .contact-form
  textarea { resize: vertical; min-height: 130px; } .form-row { display: grid;
  grid-template-columns: 1fr 1fr; gap: 0 12px; margin-bottom: 0; } .form-submit
  { width: 100%; margin-top: 4px; } @media (max-width: 480px) { .form-row {
  grid-template-columns: 1fr;   } }
</style>
